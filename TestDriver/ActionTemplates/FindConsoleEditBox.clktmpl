[Action_6]
ActionName=Verify if the right editbox is found
Action=SetVar
ActionTimeout=0
ActionEnabled=1
ActionCondition=$Control_Height$>?30
BreakpointExists=0
BreakpointEnabled=0
BreakpointCondition=
ListOfVarNames=$Exit(Found the wrong editbox)$
ListOfVarValues=
ListOfVarEvalBefore=
FailOnException=0

[Action_7]
ActionName=Cache current editbox
Action=SetVar
ActionTimeout=0
ActionEnabled=1
ActionCondition=
BreakpointExists=0
BreakpointEnabled=0
BreakpointCondition=
ListOfVarNames=$Edt_Left$$Edt_Top$$Edt_Right$$Edt_Bottom$$Edt_Width$$Edt_Height$$Edt_Text$$Edt_Class$$Edt_Handle$
ListOfVarValues=$Control_Left$$Control_Top$$Control_Right$$Control_Bottom$$Control_Width$$Control_Height$$Control_Text$$Control_Class$$Control_Handle$
ListOfVarEvalBefore=111111111
FailOnException=0

